msgstr "Caractéristiques principales :"

msgid "Affichage Dynamique :"
msgstr "Affichage dynamique :"

msgid "Le plugin récupère automatiquement les faits via l'API officielle."
msgstr "Le plugin récupère automatiquement les faits via l’API officielle."

msgid "Performance Optimisée :"
msgstr "Performance optimisée :"

msgid "Utilisation d'un système de mise en cache (transients) qui stocke le fait jusqu'au lendemain."
msgstr "Utilisation d’un système de mise en cache (transients) qui stocke le fait jusqu’au lendemain."

msgid "Personnalisation Totale :"
msgstr "Personnalisation totale :"

msgid "Interface d'administration dédiée pour modifier les couleurs et titres."
msgstr "Interface d’administration dédiée pour modifier les couleurs et titres."

msgid "Gutenberg & Shortcode :"
msgstr "Gutenberg & shortcode :"

msgid "Compatible avec l'éditeur moderne et utilisable via [chuck_fact]."
msgstr "Compatible avec l’éditeur moderne et utilisable via [chuck_fact]."

msgid "Sécurité Native :"
msgstr "Sécurité native :"

msgid "Développé avec des standards stricts (PHP 8.1+, protection CSRF, assainissement des données)."
msgstr "Développé avec des standards stricts (PHP 8.1+, protection CSRF, assainissement des données)."

msgid "Pourquoi l'utiliser ?"
msgstr "Pourquoi l’utiliser ?"

msgid "Ajouter une touche d'humour à un tableau de bord ou à une barre latérale de blog n'a jamais été aussi simple. Le projet Chuck365 prouve que même la technologie la plus sérieuse peut avoir un crochet du droit redoutable... et très drôle."
msgstr "Ajouter une touche d’humour à un tableau de bord ou à une barre latérale de blog n’a jamais été aussi simple. Le projet Chuck365 prouve que même la technologie la plus sérieuse peut avoir un crochet du droit redoutable… et très drôle."

msgid "Note : Chuck Norris n'utilise pas d'API. Les données se déplacent par peur de le contrarier."
msgstr "Note : Chuck Norris n’utilise pas d’API. Les données se déplacent par peur de le contrarier."

